#!/data/data/com.termux/files/usr/bin/bash
VERSION="1.0.0"
AUTHOR="Carbon"
GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; NC='\033[0m'

show_help() {
    cat << EOF
Usage: whale [OPTION]
Options:
  -h, --help      Show help
  -v, --version   Show version
  --update        Check for updates
  --status        System status
Examples:
  whale           Run the whale agent
  whale --help    Show help
EOF
    exit 0
}

show_version() {
    echo -e "${CYAN}Whale Agent v${VERSION}${NC}"
    echo "Author: $AUTHOR"; exit 0
}

show_status() {
    echo "===== Whale Agent Status ====="
    echo "Version:    v${VERSION}"
    echo "Hostname:   $(hostname 2>/dev/null || echo '?')"
    echo "Uptime:     $(uptime -p 2>/dev/null || echo 'N/A')"
    echo "=============================="
    exit 0
}

case "${1:-}" in
    -h|--help) show_help ;;
    -v|--version) show_version ;;
    --update) pkg upgrade whale-agent 2>/dev/null || echo "Already up to date!" ;;
    --status) show_status ;;
    "")
        echo "  __        __   _    "
        echo "  \ \      / /__| |__ "
        echo "   \ \ /\ / / _ \ '_ \\"
        echo "    \ V  V /  __/ | | |"
        echo "     \_/\_/ \___|_| |_|"
        echo ""
        echo -e "${GREEN}Whale Agent v${VERSION} -- Ready!${NC}"
        echo "  Commands: whale --help"
        ;;
    *) echo "Unknown: $1 (try whale --help)" ; exit 1 ;;
esac
